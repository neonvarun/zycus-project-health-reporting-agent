# Explanation provider: local (default), gemini, or rules
LLM_PROVIDER=local

# Local Qwen3.5-0.8B Q4_K_M model settings
LOCAL_MODEL_REPO=bartowski/Qwen_Qwen3.5-0.8B-GGUF
LOCAL_MODEL_FILE=Qwen_Qwen3.5-0.8B-Q4_K_M.gguf
LOCAL_MODEL_DIR=.models
LOCAL_MODEL_REVISION=main
LOCAL_MODEL_CONTEXT=8192
LOCAL_MODEL_MAX_TOKENS=800

# Optional: Gemini API key when LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Configurable model name
GEMINI_MODEL=gemini-2.5-flash
